# ============================================================================
# .env.example — Copy to .env (local) or set in Vercel dashboard (production)
# ============================================================================
# This file is checked into git as documentation. The real .env is gitignored.
# ============================================================================

# ── Local development (SQLite — zero-config) ───────────────────────────────
# Uses prisma/schema.dev.prisma (provider=sqlite).
# Run: npm run db:push:dev && npm run db:generate:dev
DATABASE_URL=file:./dev.db

# ── Production (Vercel + Neon Postgres free tier) ──────────────────────────
# Uses prisma/schema.prisma (provider=postgresql).
# 1. Sign up at https://neon.tech (free, GitHub login)
# 2. Create a new project — copy the connection string from the dashboard
# 3. In Vercel, set DATABASE_URL to the Neon connection string
# 4. After first deploy: `npx prisma db push` to create tables

# DATABASE_URL=postgres://user:pass@ep-xxx.region.aws.neon.tech/dbname?sslmode=require

# ── Optional: API key for write endpoints ──────────────────────────────────
# If set, all POST/PUT/PATCH/DELETE requests require x-api-key header.
# If unset, writes are open (dev convenience).
# NBODY_API_KEY=your-secret-key-here
